# ⚠️ TEMPLATE - NO COPY SECRETS HERE
# This is an EXAMPLE file showing required environment variables
# NEVER commit .env file with real values to version control!
# Each developer should copy this file to .env and add their own values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application mode: development, testing, or production
APP_ENV=development

# Enable debug mode (NEVER true in production)
DEBUG=false

# Application name
APP_NAME=Notificador de Descargas

# =============================================================================
# SECURITY & SECRETS (KEEP EMPTY - add in local .env only)
# =============================================================================

# Secret key for session management
SECRET_KEY=

# API keys (if using external services)
API_KEY=

# Authentication tokens
AUTH_TOKEN=

# Database credentials (if applicable)
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=

# AWS/Cloud credentials (if applicable)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN for error tracking (production only)
SENTRY_DSN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
ENABLE_NOTIFICATIONS=true
ENABLE_TRAY_ICON=true

# Paths for monitoring (example)
DOWNLOAD_PATHS=/Downloads,/Documents

